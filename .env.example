KAFKA_BROKERS=localhost:9092
KAFKA_TOPIC=packets-topic
KAFKA_KEY=
KAFKA_GROUP_ID=packet-local-chunker
# SASL/PLAIN auth (leave empty to disable)
KAFKA_SASL_USERNAME=
KAFKA_SASL_PASSWORD=
CHUNK_SIZE_MB=5
# Partial PCM chunk flush after no Kafka packets for this stream (ms, ingestor)
IDLE_CHUNK_FLUSH_MS=10000
OUTPUT_DIR=./output
PCM_SAMPLE_RATE=48000
PCM_CHANNELS=1

# Redis (BullMQ)
REDIS_URL=redis://localhost:6379

# AWS S3
S3_BUCKET=my-audio-bucket
S3_REGION=us-east-1
S3_ENDPOINT=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
DATABASE_URL=
# Prisma schema: packages/db/prisma (override dir if needed)
# PRISMA_PROJECT_ROOT=

# RabbitMQ (recorder: session deleted events)
RABBIT_MQ_HOST=localhost
RABBIT_MQ_USERNAME=guest
RABBIT_MQ_PASSWORD=guest
# RABBIT_MQ_PORT=5672
# RABBIT_MQ_VHOST=/

# Merge: GET /recordings/:sessionId (header X-API-KEY)
# MERGER_API_KEY=
MERGER_API_PORT=3847
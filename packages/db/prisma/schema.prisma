generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model AudioChunksLog {
  id                     Int    @id @default(autoincrement())
  sessionId              String @map("sessionId")
  userId                 String @map("userId")
  trackId                String @map("trackId")
  receivedUnixTimestamp  BigInt @map("receivedUnixTimestamp")
  firstRtpTimestamp      BigInt @map("firstRtpTimestamp")
  lastRtpTimestamp       BigInt @map("lastRtpTimestamp")
  fileS3Key              String @unique @map("fileS3Key")

  @@index([sessionId, receivedUnixTimestamp])
  @@index([sessionId, trackId, receivedUnixTimestamp])
  @@map("AudioChunksLog")
}

enum MergerTaskStatus {
  IN_PROGRESS
  COMPLETED
  FAILED
}

model MergerTask {
  id                     Int              @id @default(autoincrement())
  taskId                 String           @unique
  sessionId              String
  status                 MergerTaskStatus
  outputS3Key            String?
  createdAt              DateTime         @default(now())
  endedAt                DateTime?
  sizeBytes              BigInt?
  audioDurationInSeconds Float?
  failureReason          String?

  @@index([sessionId])
  @@index([status, createdAt])
  @@map("MergerTasks")
}
